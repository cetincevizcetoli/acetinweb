Options -Indexes
DirectoryIndex index.php

<IfModule mod_alias.c>
  RedirectMatch 403 "(^|/)\.git(/|$)"
  RedirectMatch 403 "(^|/)(app|config|docs|tools|storage|backups|_backups|mocap|archive|arsiv|ar.iv)(/|$)"
  RedirectMatch 403 "\.(sqlite|sqlite-|db|bak|zip|env|pem|key|sql)$"
</IfModule>

<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteRule (^|/)\.git(/|$) - [F,L]
  RewriteRule ^_.*\.php$ - [F,L,NC]
  RewriteRule ^(app|config|docs|tools|storage|backups|_backups|mocap|archive|arsiv|ar.iv)(/|$) - [F,L,NC]
  RewriteCond %{REMOTE_ADDR} !^127\.
  RewriteCond %{REMOTE_ADDR} !^::1$
  RewriteCond %{REMOTE_ADDR} !^::ffff:127\.
  RewriteRule ^admin-local(/|$) - [F,L,NC]
  RewriteRule ^guven.*\.txt$ - [F,L,NC]
  RewriteRule (^|/)(composer\.(json|lock)|package(-lock)?\.json|\.env|config/local\.php)$ - [F,L,NC]
  RewriteRule \.(sqlite|sqlite-|db|bak|zip|env|pem|key|sql)$ - [F,L,NC]
</IfModule>

<FilesMatch "(?i)^(\.env|composer\.(json|lock)|package(-lock)?\.json)$|.*\.(sqlite|db|bak|zip|pem|key|sql)$">
  Require all denied
</FilesMatch>
