Options -Indexes
DirectoryIndex index.php

<IfModule mod_alias.c>
  RedirectMatch 403 "(^|/)\.git(/|$)"
  RedirectMatch 403 "(^|/)(app|config|tools|storage|_backups|mocap|arşiv)(/|$)"
  RedirectMatch 403 "(^|/)(README|TEST_REPORT|AGENTS|agents|VERSION|V7_MEDIA_LINK_FIX|DEPLOY_CHECKLIST)\.(txt|md)$"
  RedirectMatch 403 "\.(sqlite|sqlite-|db|bak|zip|env|pem|key|sql)$"
</IfModule>

<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteRule (^|/)\.git(/|$) - [F,L]
  RewriteRule ^(app|config|tools|storage|_backups|mocap|arşiv)(/|$) - [F,L,NC]
  RewriteRule ^(README|TEST_REPORT|AGENTS|agents|VERSION|V7_MEDIA_LINK_FIX|DEPLOY_CHECKLIST)\.(txt|md)$ - [F,L,NC]
  RewriteRule (^|/)(composer\.(json|lock)|package(-lock)?\.json|\.env|config/local\.php)$ - [F,L,NC]
  RewriteRule \.(sqlite|sqlite-|db|bak|zip|env|pem|key|sql)$ - [F,L,NC]
</IfModule>

<FilesMatch "(?i)^(\.env|composer\.(json|lock)|package(-lock)?\.json)$|.*\.(sqlite|db|bak|zip|pem|key|sql)$">
  Require all denied
</FilesMatch>
