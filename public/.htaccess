Options -Indexes
DirectoryIndex index.php

<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteRule (^|/)\. - [F,L]
  RewriteRule ^(README|TEST_REPORT|AGENTS|agents|VERSION|V7_MEDIA_LINK_FIX|DEPLOY_CHECKLIST|SYSTEM_OVERVIEW|ARCHITECTURE_REFACTOR_CHECKLIST|REFACTOR_GIT_RULES|LIVE_DEPLOY_PLAN)\.(txt|md)$ - [F,L,NC]
  RewriteRule ^guven.*\.txt$ - [F,L,NC]
  RewriteRule \.(sqlite|sqlite-|db|bak|zip|env|pem|key|sql)$ - [F,L,NC]
</IfModule>

<FilesMatch "(?i)^(\.env|composer\.(json|lock)|package(-lock)?\.json)$|.*\.(sqlite|db|bak|zip|pem|key|sql)$">
  Require all denied
</FilesMatch>

Header set X-Content-Type-Options "nosniff"
